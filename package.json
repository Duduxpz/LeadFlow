{
  "name": "leadflow",
  "version": "1.0.0",
  "description": "Plataforma SaaS para captura e classificação de leads",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev -w apps/backend",
    "dev:frontend": "npm run dev -w apps/frontend",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1"
  }
}
